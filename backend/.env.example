# Cloud SQL Postgres — asyncpg DSN
# Local dev (public IP or Cloud SQL Proxy on 127.0.0.1:5432):
#   DATABASE_URL=postgresql://postgres:PASSWORD@127.0.0.1:5432/email_composer
# Cloud Run (Unix socket via --add-cloudsql-instances):
#   DATABASE_URL=postgresql://postgres:PASSWORD@/email_composer?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# GCP project — BigQuery + Vertex AI
GCP_PROJECT_ID=gtm-cloud-helpdesk
BQ_DATASET=email_composer_vectors
BQ_TABLE=canned_responses
EMBEDDING_LOCATION=us-central1
EMBEDDING_MODEL=text-embedding-005

# Gemini — leave GEMINI_API_KEY blank to use Vertex AI (service-account auth)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview

# Auth — override in production
JWT_SECRET_KEY=change-me-in-production
SEED_ADMIN_EMAIL=admin@email-composer.ai
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=System Admin

# CORS — comma-separated origins or * for dev
ALLOWED_ORIGINS=*
